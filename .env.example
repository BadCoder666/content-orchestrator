# Copy to .env (gitignored) and fill in. Your launchd wrapper sources this file
# before running the dispatcher, so nothing secret ever lives in the code.

# --- Secrets (required) ---------------------------------------------------
# Slack bot token. The bot needs scopes: chat:write, channels:history,
# channels:read, groups:history, groups:read (+ files:write, im:write if you
# also DM files). Invite the bot to each channel it must read/post in.
export SLACK_BOT_TOKEN=xoxb-your-token

# Reddit "script" app (https://www.reddit.com/prefs/apps) — application-only OAuth.
export REDDIT_CLIENT_ID=your-id
export REDDIT_CLIENT_SECRET=your-secret

# Only needed if DRAFT_BACKEND=api (headless drafting via the Anthropic API).
export ANTHROPIC_API_KEY=

# --- Deployment config (optional; sensible defaults in config.py) ----------
export ORCH_TZ=America/New_York
export DRAFT_BACKEND=inapp                       # "inapp" (subscription) | "api" (headless)

# Slack channel IDs for the two example projects
export NEWSLETTER_SLACK_CHANNEL=C00000NEWS
export COMPANY_SLACK_FALLBACK=C00000COMP

# Source feeds / identity
export SUBSTACK_FEEDS=https://yourpublication.substack.com/feed
export REDDIT_USER_AGENT=macos:content-orchestrator:v0.1 (by /u/your_username)

# Overnight network resilience (macOS laptop). Phone-hotspot SSID fallback(s),
# comma-separated; the hotspot must be broadcasting for the fallback to work.
export WIFI_IFACE=en0
export HOTSPOT_SSIDS=My Phone,My Phone 5G

# Optional external project folders (leave unset if you don't use them)
# export COMPANY_REPO=$HOME/projects/company
# export NEWSLETTER_DIR=$HOME/projects/newsletter
